generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// ⓪ user — 用户
// ============================================================

model user {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  role       String   @default("user")
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  inspection_records inspection_record[]
  analysis_reports   analysis_report[]
  tasks              task[]

  @@map("user")
}

// ============================================================
// ① equipment — 设备/机头档案
// ============================================================

model equipment {
  id                  String    @id @default(cuid())
  machine_no          String    @unique
  model               String
  manufacturer        String?
  production_date     DateTime?
  status              String    @default("在用")
  current_location    String?
  total_working_hours Float     @default(0)
  remark              String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  parts               part[]
  inspection_records  inspection_record[]

  @@map("equipment")
}

// ============================================================
// ② part_category — 零件类别
// ============================================================

model part_category {
  id                   String  @id @default(cuid())
  name                 String  @unique
  code                 String  @unique
  description          String?
  standard_param_count Int     @default(40)

  parts                part[]
  parameter_template   parameter_template?

  @@map("part_category")
}

// ============================================================
// ③ part — 零件档案
// ============================================================

model part {
  id            String  @id @default(cuid())
  code          String  @unique
  name          String
  category_id   String
  specification String?
  material      String?
  supplier      String?
  equipment_id  String?
  install_date  DateTime?
  working_hours Float   @default(0)
  status        String  @default("在用")
  remark        String?

  category      part_category @relation(fields: [category_id], references: [id])
  equipment     equipment?    @relation(fields: [equipment_id], references: [id])
  data_items    inspection_data_item[]

  @@map("part")
}

// ============================================================
// ④ parameter_template — 检测参数模板
// ============================================================

model parameter_template {
  id          String  @id @default(cuid())
  category_id String  @unique
  name        String
  version     Int     @default(1)

  category    part_category   @relation(fields: [category_id], references: [id])
  items       parameter_item[]

  @@map("parameter_template")
}

// ============================================================
// ⑤ parameter_item — 参数项定义
// ============================================================

model parameter_item {
  id           String  @id @default(cuid())
  template_id  String
  param_name   String
  param_code   String
  unit         String?
  data_type    String  @default("number")
  standard_min Float?
  standard_max Float?
  optimal_min  Float?
  optimal_max  Float?
  sort_order   Int     @default(0)
  options      String?

  template     parameter_template    @relation(fields: [template_id], references: [id], onDelete: Cascade)
  data_items   inspection_data_item[]

  @@map("parameter_item")
}

// ============================================================
// ⑥ inspection_record — 检测记录头
// ============================================================

model inspection_record {
  id              String    @id @default(cuid())
  record_no       String    @unique
  equipment_id    String?
  inspector       String
  batch_no        String?
  inspection_date DateTime
  overall_result  String    @default("待检")
  remark          String?
  user_id         String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  equipment  equipment?             @relation(fields: [equipment_id], references: [id])
  user       user?                  @relation(fields: [user_id], references: [id])
  data_items inspection_data_item[]

  @@map("inspection_record")
}

// ============================================================
// ⑦ inspection_data_item — 检测数据明细
// ============================================================

model inspection_data_item {
  id             String  @id @default(cuid())
  record_id      String
  part_id        String
  param_item_id  String
  value_number   Float?
  value_text     String?
  is_qualified   Boolean?
  is_optimal     Boolean?

  record     inspection_record @relation(fields: [record_id], references: [id], onDelete: Cascade)
  part       part              @relation(fields: [part_id], references: [id])
  param_item  parameter_item    @relation(fields: [param_item_id], references: [id])

  @@index([record_id])
  @@index([part_id])
  @@index([param_item_id])
  @@map("inspection_data_item")
}

// ============================================================
// ⑧ analysis_report — 分析报告
// ============================================================

model analysis_report {
  id          String   @id @default(cuid())
  report_no   String   @unique
  title       String
  type        String
  period      String?
  summary     String?
  conclusion  String?
  author      String
  status      String   @default("草稿")
  user_id     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user user? @relation(fields: [user_id], references: [id])

  @@map("analysis_report")
}

// ============================================================
// ⑨ task — 任务
// ============================================================

model task {
  id          String    @id @default(cuid())
  title       String
  description String?
  priority    String    @default("中")
  status      String    @default("待办")
  assignee    String?
  due_date    DateTime?
  task_type   String    @default("常规")
  user_id     String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  user user? @relation(fields: [user_id], references: [id])

  @@map("task")
}

// ============================================================
// ⑩ meeting — 会议
// ============================================================

model meeting {
  id              String   @id @default(cuid())
  title           String
  meeting_date    DateTime
  location        String?
  organizer       String
  participants    String?
  minutes_content String?
  status          String   @default("待召开")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  resolutions meeting_resolution[]

  @@map("meeting")
}

// ============================================================
// ⑪ meeting_resolution — 会议决议
// ============================================================

model meeting_resolution {
  id                 String   @id @default(cuid())
  meeting_id         String
  content            String
  responsible_person String?
  due_date           DateTime?
  status             String   @default("待执行")

  meeting meeting @relation(fields: [meeting_id], references: [id], onDelete: Cascade)

  @@map("meeting_resolution")
}

// ============================================================
// ⑫ document — 文件归档
// ============================================================

model document {
  id                String   @id @default(cuid())
  title             String
  category          String
  file_path         String?
  related_report_id String?
  archived          Boolean  @default(false)
  created_at        DateTime @default(now())

  @@map("document")
}

// ============================================================
// ⑬ attendance_record — 考勤记录
// ============================================================

model attendance_record {
  id          String   @id @default(cuid())
  date        DateTime
  member_name String
  status      String
  remark      String?

  @@map("attendance_record")
}